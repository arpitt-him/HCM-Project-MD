// ============================================================
// HCM Platform — HRIS Domain Schema
// Version: v0.1
// Status: Draft
// Covers: Person, Employment, Assignment, Compensation Record,
//         Org Unit, Job, Position, Leave Request, Document,
//         Onboarding Plan, Onboarding Task,
//         Person Address (sub-record)
// Note: References are standalone — no FK constraints applied.
//       Column names are consistent with payroll_core.dbml
//       to support cross-schema FK addition without renaming.
// ============================================================

// ============================================================
// ENUMS
// ============================================================

enum person_status {
  ACTIVE
  INACTIVE
  DECEASED
  RESTRICTED
  ARCHIVED
}

enum employment_type {
  EMPLOYEE
  CONTRACTOR
  INTERN
  SEASONAL
}

enum employment_status {
  PENDING
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  CLOSED
}

enum full_part_time_status {
  FULL_TIME
  PART_TIME
}

enum regular_temporary_status {
  REGULAR
  TEMPORARY
  SEASONAL
}

enum flsa_status {
  EXEMPT
  NON_EXEMPT
}

enum assignment_type {
  PRIMARY
  SECONDARY
  TEMPORARY
  SUPPLEMENTAL
  OVERRIDE
}

enum assignment_status {
  ACTIVE
  PENDING
  CLOSED
  CANCELLED
}

enum compensation_rate_type {
  HOURLY
  SALARY
  COMMISSION
  CONTRACT
  DIFFERENTIAL
}

enum compensation_status {
  PENDING
  ACTIVE
  CLOSED
  CANCELLED
  SUPERSEDED
}

enum pay_frequency {
  WEEKLY
  BIWEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum approval_status {
  PENDING
  APPROVED
  REJECTED
}

enum leave_type {
  PTO
  VACATION
  SICK
  PERSONAL
  LOA
  FMLA
  STD
  LTD
  MILITARY
  JURY_DUTY
  HOLIDAY
}

enum leave_status {
  REQUESTED
  APPROVED
  DENIED
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum payroll_impact_type {
  PAID_SUBSTITUTION
  UNPAID_SUPPRESSION
  DISABILITY_PAY
  NO_IMPACT
}

enum document_type {
  I9
  W4
  OFFER_LETTER
  CONTRACT
  CERTIFICATION
  LICENSE
  IDENTIFICATION
  POLICY_ACKNOWLEDGEMENT
  PERFORMANCE_REVIEW
  OTHER
}

enum document_status {
  DRAFT
  ACTIVE
  EXPIRED
  SUPERSEDED
  ARCHIVED
}

enum onboarding_plan_status {
  CREATED
  IN_PROGRESS
  BLOCKING_COMPLETE
  COMPLETE
  CANCELLED
}

enum onboarding_task_type {
  DOCUMENT_SUBMISSION
  SYSTEM_ACCESS
  TRAINING
  POLICY_ACKNOWLEDGEMENT
  BENEFITS_ENROLLMENT
  EQUIPMENT_SETUP
  ORIENTATION
  OTHER
}

enum onboarding_task_status {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  WAIVED
  OVERDUE
}

enum org_unit_type {
  LEGAL_ENTITY
  DIVISION
  BUSINESS_UNIT
  DEPARTMENT
  COST_CENTER
  LOCATION
  REGION
}

enum org_status {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum work_location_type {
  OFFICE
  REMOTE
  HYBRID
}

enum job_status {
  ACTIVE
  INACTIVE
}

enum flsa_classification {
  EXEMPT
  NON_EXEMPT
  INDEPENDENT_CONTRACTOR
}

enum eeo_category {
  EXEC_SENIOR_OFFICIALS
  FIRST_MID_OFFICIALS
  PROFESSIONALS
  TECHNICIANS
  SALES
  ADMIN_SUPPORT
  CRAFT_WORKERS
  OPERATIVES
  LABORERS
  SERVICE_WORKERS
}

enum position_status {
  OPEN
  FILLED
  FROZEN
  CLOSED
}

// ============================================================
// PERSON
// ============================================================

Table person {
  person_id                   uuid            [pk, not null, note: "System-generated. Immutable. Enduring human identity key."]
  person_number               varchar(50)     [null, note: "Optional human-facing or integration-facing identifier"]
  legal_first_name            varchar(100)    [not null]
  legal_middle_name           varchar(100)    [null]
  legal_last_name             varchar(100)    [not null]
  name_suffix                 varchar(20)     [null]
  preferred_name              varchar(100)    [null]
  date_of_birth               date            [not null]
  national_identifier         varchar(500)    [null, note: "Encrypted at rest. SSN for US. Access-controlled."]
  national_identifier_type    varchar(50)     [null, note: "SSN, SIN, NIN, etc."]
  gender                      varchar(50)     [null, note: "Self-identified; controlled vocabulary"]
  pronouns                    varchar(100)    [null, note: "Self-identified"]
  citizenship_status          varchar(100)    [null]
  work_authorization_status   varchar(100)    [null]
  work_authorization_exp_date date            [null]
  language_preference         varchar(20)     [null]
  marital_status              varchar(50)     [null]
  veteran_status              varchar(50)     [null]
  disability_status           varchar(50)     [null]
  person_status               person_status   [not null]
  creation_timestamp          timestamp       [not null]
  last_update_timestamp       timestamp       [not null]
  last_updated_by             varchar(200)    [not null]

  indexes {
    person_number
    person_status
    (legal_last_name, legal_first_name)
  }
}

// ============================================================
// PERSON ADDRESS (sub-record; supports history)
// ============================================================

Table person_address {
  person_address_id       uuid          [pk, not null]
  person_id               uuid          [not null]
  address_type            varchar(50)   [not null, note: "PRIMARY, MAILING, PRIOR"]
  address_line_1          varchar(200)  [not null]
  address_line_2          varchar(200)  [null]
  city                    varchar(100)  [not null]
  state_code              varchar(10)   [not null, note: "ISO 3166-2"]
  postal_code             varchar(20)   [not null]
  country_code            varchar(5)    [not null, note: "ISO 3166-1 alpha-2"]
  phone_primary           varchar(30)   [null]
  phone_secondary         varchar(30)   [null]
  email_personal          varchar(200)  [null]
  effective_start_date    date          [not null]
  effective_end_date      date          [null]
  created_by              uuid          [not null]
  creation_timestamp      timestamp     [not null]

  indexes {
    person_id
    (person_id, address_type, effective_start_date)
  }
}

// ============================================================
// PERSON EMERGENCY CONTACT
// ============================================================

Table person_emergency_contact {
  emergency_contact_id    uuid          [pk, not null]
  person_id               uuid          [not null]
  contact_name            varchar(200)  [not null]
  relationship            varchar(100)  [null]
  phone                   varchar(30)   [null]
  email                   varchar(200)  [null]
  primary_flag            boolean       [not null, default: false]
  created_by              uuid          [not null]
  creation_timestamp      timestamp     [not null]

  indexes {
    person_id
  }
}

// ============================================================
// ORG UNIT
// ============================================================

Table org_unit {
  org_unit_id             uuid            [pk, not null, note: "System-generated. Immutable."]
  org_unit_type           org_unit_type   [not null]
  org_unit_code           varchar(50)     [not null]
  org_unit_name           varchar(200)    [not null]
  parent_org_unit_id      uuid            [null, note: "Null for root nodes; must not create cycles"]
  org_status              org_status      [not null]
  effective_start_date    date            [not null]
  effective_end_date      date            [null]
  // Legal entity additional fields
  tax_registration_number varchar(50)     [null, note: "EIN for US legal entities"]
  country_code            varchar(5)      [null, note: "ISO 3166-1 alpha-2; required for legal entities"]
  state_of_incorporation  varchar(10)     [null]
  legal_entity_type       varchar(50)     [null, note: "CORPORATION, LLC, PARTNERSHIP, etc."]
  // Location additional fields
  address_line_1          varchar(200)    [null]
  address_line_2          varchar(200)    [null]
  city                    varchar(100)    [null]
  state_code              varchar(10)     [null, note: "US state code; drives tax jurisdiction"]
  postal_code             varchar(20)     [null]
  locality_code           varchar(50)     [null, note: "Local tax jurisdiction code"]
  work_location_type      work_location_type [null]
  created_by              uuid            [not null]
  creation_timestamp      timestamp       [not null]
  last_updated_by         uuid            [not null]
  last_update_timestamp   timestamp       [not null]

  indexes {
    org_unit_type
    org_status
    parent_org_unit_id
    org_unit_code
  }
}

// ============================================================
// JOB
// ============================================================

Table job {
  job_id                  uuid                [pk, not null, note: "System-generated. Immutable."]
  job_code                varchar(50)         [not null, unique]
  job_title               varchar(200)        [not null]
  job_family              varchar(100)        [null]
  job_level               varchar(50)         [null]
  flsa_classification     flsa_classification [not null]
  eeo_category            eeo_category        [not null]
  job_status              job_status          [not null]
  effective_start_date    date                [not null]
  effective_end_date      date                [null]
  created_by              uuid                [not null]
  creation_timestamp      timestamp           [not null]
  last_updated_by         uuid                [not null]
  last_update_timestamp   timestamp           [not null]

  indexes {
    job_code
    job_status
    flsa_classification
  }
}

// ============================================================
// POSITION
// ============================================================

Table position {
  position_id             uuid              [pk, not null, note: "System-generated. Immutable."]
  job_id                  uuid              [not null]
  org_unit_id             uuid              [not null]
  position_title          varchar(200)      [null, note: "Override title; if null, inherits from job_title"]
  headcount_budget        int               [null]
  position_status         position_status   [not null]
  effective_start_date    date              [not null]
  effective_end_date      date              [null]
  created_by              uuid              [not null]
  creation_timestamp      timestamp         [not null]
  last_updated_by         uuid              [not null]
  last_update_timestamp   timestamp         [not null]

  indexes {
    job_id
    org_unit_id
    position_status
  }
}

// ============================================================
// EMPLOYMENT
// ============================================================

Table employment {
  employment_id                 uuid                      [pk, not null, note: "System-generated. Immutable. Payroll anchor."]
  person_id                     uuid                      [not null]
  legal_entity_id               uuid                      [not null, note: "Org unit of type LEGAL_ENTITY"]
  employer_id                   uuid                      [not null, note: "Same as legal_entity_id in standard deployments"]
  employee_number               varchar(50)               [not null]
  employment_type               employment_type           [not null]
  employment_start_date         date                      [not null]
  employment_end_date           date                      [null]
  original_hire_date            date                      [null]
  termination_date              date                      [null]
  employment_status             employment_status         [not null]
  full_or_part_time_status      full_part_time_status     [not null]
  regular_or_temporary_status   regular_temporary_status  [not null]
  flsa_status                   flsa_status               [not null]
  payroll_context_id            uuid                      [not null]
  primary_work_location_id      uuid                      [not null, note: "References org_unit of type LOCATION"]
  primary_department_id         uuid                      [not null, note: "References org_unit of type DEPARTMENT"]
  manager_employment_id         uuid                      [null, note: "Direct manager; self-referencing"]
  rehire_flag                   boolean                   [not null, default: false]
  prior_employment_id           uuid                      [null, note: "Prior episode on rehire"]
  primary_flag                  boolean                   [not null, default: true, note: "True if primary when concurrent employments exist"]
  payroll_eligibility_flag      boolean                   [not null, default: true]
  benefits_eligibility_flag     boolean                   [not null, default: true]
  time_tracking_required_flag   boolean                   [not null, default: false]
  creation_timestamp            timestamp                 [not null]
  last_update_timestamp         timestamp                 [not null]
  last_updated_by               varchar(200)              [not null]

  indexes {
    person_id
    legal_entity_id
    employment_status
    employee_number
    manager_employment_id
    prior_employment_id
    payroll_context_id
    primary_work_location_id
    primary_department_id
  }
}

// ============================================================
// ASSIGNMENT
// ============================================================

Table assignment {
  assignment_id           uuid                [pk, not null, note: "System-generated. Immutable."]
  employment_id           uuid                [not null, note: "Payroll anchor — never person_id"]
  job_id                  uuid                [not null]
  position_id             uuid                [null, note: "Null if position management not in use"]
  department_id           uuid                [not null, note: "References org_unit"]
  location_id             uuid                [not null, note: "References org_unit of type LOCATION; drives tax jurisdiction"]
  payroll_context_id      uuid                [not null]
  plan_id                 uuid                [null]
  assignment_type         assignment_type     [not null]
  assignment_status       assignment_status   [not null]
  assignment_priority     int                 [null]
  assignment_start_date   date                [not null]
  assignment_end_date     date                [null]
  created_by              uuid                [not null]
  creation_timestamp      timestamp           [not null]
  last_updated_by         uuid                [not null]
  last_update_timestamp   timestamp           [not null]

  indexes {
    employment_id
    job_id
    position_id
    location_id
    department_id
    assignment_status
    assignment_type
    (employment_id, assignment_type, assignment_start_date)
  }
}

// ============================================================
// COMPENSATION RECORD
// ============================================================

Table compensation_record {
  compensation_id         uuid                      [pk, not null, note: "System-generated. Immutable."]
  employment_id           uuid                      [not null, note: "Payroll anchor"]
  rate_type               compensation_rate_type    [not null]
  base_rate               decimal(18,4)             [not null]
  rate_currency           varchar(5)                [not null, default: 'USD', note: "ISO 4217"]
  annual_equivalent       decimal(18,4)             [null, note: "System-calculated"]
  pay_frequency           pay_frequency             [not null]
  effective_start_date    date                      [not null]
  effective_end_date      date                      [null]
  compensation_status     compensation_status       [not null]
  change_reason_code      varchar(50)               [not null]
  approval_status         approval_status           [not null]
  approved_by             uuid                      [null]
  approval_timestamp      timestamp                 [null]
  primary_rate_flag       boolean                   [not null, default: false]
  created_by              uuid                      [not null]
  creation_timestamp      timestamp                 [not null]
  last_updated_by         uuid                      [not null]
  last_update_timestamp   timestamp                 [not null]

  indexes {
    employment_id
    compensation_status
    effective_start_date
    (employment_id, rate_type, effective_start_date)
    primary_rate_flag
  }
}

// ============================================================
// LEAVE REQUEST
// ============================================================

Table leave_request {
  leave_request_id        uuid                  [pk, not null, note: "System-generated. Immutable."]
  employment_id           uuid                  [not null]
  leave_type              leave_type            [not null]
  request_date            date                  [not null]
  leave_start_date        date                  [not null]
  leave_end_date          date                  [not null]
  actual_return_date      date                  [null]
  leave_status            leave_status          [not null]
  leave_reason_code       varchar(50)           [not null]
  payroll_impact_type     payroll_impact_type   [not null]
  leave_balance_impact    decimal(10,4)         [null, note: "Hours or days deducted from balance"]
  approved_by             uuid                  [null]
  approval_timestamp      timestamp             [null]
  hr_contact_id           uuid                  [null]
  fmla_eligible_flag      boolean               [null, default: false]
  created_by              uuid                  [not null]
  creation_timestamp      timestamp             [not null]
  last_updated_by         uuid                  [not null]
  last_update_timestamp   timestamp             [not null]

  indexes {
    employment_id
    leave_status
    leave_type
    leave_start_date
    (employment_id, leave_start_date, leave_end_date)
  }
}

// ============================================================
// DOCUMENT
// ============================================================

Table document {
  document_id                 uuid              [pk, not null, note: "System-generated. Immutable."]
  person_id                   uuid              [not null, note: "Always associated with a Person"]
  employment_id               uuid              [null, note: "Null for person-level documents"]
  document_type               document_type     [not null]
  document_name               varchar(200)      [not null]
  document_version            int               [not null, default: 1]
  document_status             document_status   [not null]
  effective_date              date              [not null]
  expiration_date             date              [null]
  storage_reference           varchar(500)      [not null, note: "Secure reference to stored file"]
  file_format                 varchar(20)       [not null]
  upload_date                 timestamp         [not null]
  uploaded_by                 uuid              [not null]
  verified_by                 uuid              [null]
  verification_date           timestamp         [null]
  superseded_by_document_id   uuid              [null]
  created_by                  uuid              [not null]
  creation_timestamp          timestamp         [not null]

  indexes {
    person_id
    employment_id
    document_type
    document_status
    expiration_date
    superseded_by_document_id
  }
}

// ============================================================
// ONBOARDING PLAN
// ============================================================

Table onboarding_plan {
  onboarding_plan_id        uuid                      [pk, not null, note: "System-generated. Immutable."]
  employment_id             uuid                      [not null]
  plan_template_id          uuid                      [null]
  plan_status               onboarding_plan_status    [not null]
  target_start_date         date                      [not null]
  completion_date           date                      [null]
  assigned_hr_contact_id    uuid                      [null]
  created_by                uuid                      [not null]
  creation_timestamp        timestamp                 [not null]
  last_updated_by           uuid                      [not null]
  last_update_timestamp     timestamp                 [not null]

  indexes {
    employment_id
    plan_status
  }
}

// ============================================================
// ONBOARDING TASK
// ============================================================

Table onboarding_task {
  task_id               uuid                      [pk, not null, note: "System-generated. Immutable."]
  onboarding_plan_id    uuid                      [not null]
  task_type             onboarding_task_type      [not null]
  task_name             varchar(200)              [not null]
  task_owner_role       varchar(100)              [not null]
  task_owner_user_id    uuid                      [null]
  due_date              date                      [not null]
  completion_date       date                      [null]
  task_status           onboarding_task_status    [not null]
  blocking_flag         boolean                   [not null, default: false]
  waiver_reason         varchar(500)              [null]
  waived_by             uuid                      [null]
  created_by            uuid                      [not null]
  creation_timestamp    timestamp                 [not null]

  indexes {
    onboarding_plan_id
    task_status
    blocking_flag
    (onboarding_plan_id, blocking_flag, task_status)
  }
}

// ============================================================
// TABLE GROUPS
// ============================================================

TableGroup person_identity {
  person
  person_address
  person_emergency_contact
}

TableGroup org_structure {
  org_unit
  job
  position
}

TableGroup employment_core {
  employment
  assignment
  compensation_record
}

TableGroup workforce_management {
  leave_request
  document
  onboarding_plan
  onboarding_task
}
