// ============================================================
// HCM Platform — HRIS Domain Schema
// Version: v0.5
// Status: Draft
// Changes from v0.4:
//   - Added lkp_legal_entity_type lookup table
//   - org_unit: added legal_entity_type_id (FK → lkp_legal_entity_type)
//   - org_unit: removed legacy legal_entity_type varchar(50) — replaced
//     by integer FK; column was dropped from DB
//   - leave_request: added notes varchar(1000)
//   - Added document_download_audit table
//   - Added person_social_profile table (1:1 with person)
//   - Added work_queue_item table
//   - TableGroups updated: lkp_organization, person_identity,
//     workforce_management; new work_queue group added
// Changes from v0.3:
//   - Consolidated: hcm_hris_lookups.dbml and hcm_platform.dbml
//     absorbed into this file
// Changes from v0.2:
//   - org_unit: added legal_entity_id (pre-existing in DB; gap corrected)
//     Self-references for LEGAL_ENTITY rows; points to owning entity
//     for all other org unit types. Nullable — legal entities were
//     present before the column was tracked in the DBML.
//   - job: added legal_entity_id (NOT NULL) — jobs are now scoped to
//     a legal entity. Job_Code uniqueness is per legal entity, not global.
//     Composite unique index (legal_entity_id, job_code) replaces the
//     prior single-column unique constraint on job_code.
// Changes from v0.1:
//   - All PostgreSQL enum types removed
//   - Enum columns replaced with integer FK columns
//     referencing lookup tables
//   - FK column naming convention: {concept}_id → integer
// Covers: Person, Employment, Assignment, Compensation Record,
//         Org Unit, Job, Position, Leave Request, Document,
//         Document Download Audit, Person Social Profile,
//         Work Queue Item, Onboarding Plan, Onboarding Task,
//         Person Address, Employee Event,
//         HRIS lookup tables, Platform audit event
// Note: References are standalone — no FK constraints applied.
//       Column names are consistent with hcm_payroll.dbml
//       to support cross-schema FK addition without renaming.
// ============================================================


// ============================================================
// LOOKUP TABLES
// Naming: lkp_ prefix | snake_case | SERIAL INT primary keys
// ============================================================

// ────────────────────────────────────────────────────────────
// GROUP 1: PERSON & EMPLOYEE LIFECYCLE
// ────────────────────────────────────────────────────────────

Table lkp_person_status {
  id                integer      [pk, increment, note: 'SERIAL primary key']
  code              varchar(50)  [unique, not null, note: 'e.g. ACTIVE, INACTIVE, DECEASED, RESTRICTED, ARCHIVED']
  label             varchar(100) [not null]
  description       text
  allows_employment boolean      [not null, default: true, note: 'Whether this status permits active employment records']
  sort_order        int          [not null, default: 0]
  is_active         boolean      [not null, default: true]
  is_default        boolean      [not null, default: false]
  created_at        timestamptz  [not null, default: `now()`]
  updated_at        timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of a person record'
}

Table lkp_employee_event_type {
  id                  integer      [pk, increment]
  code                varchar(50)  [unique, not null, note: 'e.g. HIRE, REHIRE, TERMINATION, PROMOTION, TRANSFER, LOA_START, LOA_RETURN']
  label               varchar(100) [not null]
  description         text
  event_category      varchar(30)  [not null, note: 'Grouping: ONBOARDING, SEPARATION, MOVEMENT, COMPENSATION, LEAVE']
  is_separation       boolean      [not null, default: false, note: 'True if this event ends employment']
  triggers_onboarding boolean      [not null, default: false, note: 'True if this event initiates onboarding workflow']
  sort_order          int          [not null, default: 0]
  is_active           boolean      [not null, default: true]
  is_default          boolean      [not null, default: false]
  created_at          timestamptz  [not null, default: `now()`]
  updated_at          timestamptz  [not null, default: `now()`]

  Note: 'Classifies employee lifecycle events (hire, termination, transfer, etc.)'
}

// ────────────────────────────────────────────────────────────
// GROUP 2: EMPLOYMENT CLASSIFICATION
// ────────────────────────────────────────────────────────────

Table lkp_employment_type {
  id                integer      [pk, increment]
  code              varchar(50)  [unique, not null, note: 'e.g. EMPLOYEE, CONTRACTOR, INTERN, VOLUNTEER']
  label             varchar(100) [not null]
  description       text
  is_w2             boolean      [not null, default: true, note: 'W-2 tax treatment (vs 1099)']
  benefits_eligible boolean      [not null, default: false, note: 'Default benefits eligibility']
  sort_order        int          [not null, default: 0]
  is_active         boolean      [not null, default: true]
  is_default        boolean      [not null, default: false]
  created_at        timestamptz  [not null, default: `now()`]
  updated_at        timestamptz  [not null, default: `now()`]

  Note: 'Worker classification type (Employee, Contractor, Intern, etc.)'
}

Table lkp_employment_status {
  id                integer      [pk, increment]
  code              varchar(50)  [unique, not null, note: 'e.g. ACTIVE, ON_LEAVE, SUSPENDED, TERMINATED, RETIRED']
  label             varchar(100) [not null]
  description       text
  is_payroll_active boolean      [not null, default: true, note: 'Whether employment feeds active payroll']
  sort_order        int          [not null, default: 0]
  is_active         boolean      [not null, default: true]
  is_default        boolean      [not null, default: false]
  created_at        timestamptz  [not null, default: `now()`]
  updated_at        timestamptz  [not null, default: `now()`]

  Note: 'Current state of an employment record'
}

Table lkp_full_part_time_status {
  id                integer       [pk, increment]
  code              varchar(50)   [unique, not null, note: 'e.g. FULL_TIME, PART_TIME, PRN, ON_CALL']
  label             varchar(100)  [not null]
  description       text
  min_hours_week    decimal(5,2)  [note: 'Minimum weekly hours threshold for this classification']
  max_hours_week    decimal(5,2)  [note: 'Maximum weekly hours threshold']
  benefits_eligible boolean       [not null, default: false, note: 'ACA / plan eligibility default']
  sort_order        int           [not null, default: 0]
  is_active         boolean       [not null, default: true]
  is_default        boolean       [not null, default: false]
  created_at        timestamptz   [not null, default: `now()`]
  updated_at        timestamptz   [not null, default: `now()`]

  Note: 'Full-time vs part-time classification (ACA, benefits eligibility)'
}

Table lkp_regular_temporary_status {
  id           integer      [pk, increment]
  code         varchar(50)  [unique, not null, note: 'e.g. REGULAR, TEMPORARY, SEASONAL, PROJECT_BASED']
  label        varchar(100) [not null]
  description  text
  has_end_date boolean      [not null, default: false, note: 'Whether assignments of this type require a defined end date']
  sort_order   int          [not null, default: 0]
  is_active    boolean      [not null, default: true]
  is_default   boolean      [not null, default: false]
  created_at   timestamptz  [not null, default: `now()`]
  updated_at   timestamptz  [not null, default: `now()`]

  Note: 'Regular vs temporary/seasonal employment classification'
}

// ────────────────────────────────────────────────────────────
// GROUP 3: FLSA & COMPLIANCE
// ────────────────────────────────────────────────────────────

Table lkp_flsa_classification {
  id               integer       [pk, increment]
  code             varchar(50)   [unique, not null, note: 'e.g. EXECUTIVE, ADMINISTRATIVE, PROFESSIONAL, COMPUTER, OUTSIDE_SALES, HIGHLY_COMPENSATED']
  label            varchar(100)  [not null]
  description      text
  overtime_eligible boolean      [not null, default: false, note: 'Whether this classification is eligible for overtime']
  sort_order       int           [not null, default: 0]
  is_active        boolean       [not null, default: true]
  is_default       boolean       [not null, default: false]
  created_at       timestamptz   [not null, default: `now()`]
  updated_at       timestamptz   [not null, default: `now()`]

  Note: 'FLSA exemption classification (Executive, Administrative, Professional, etc.)'
}

Table lkp_flsa_status {
  id                     integer      [pk, increment]
  code                   varchar(50)  [unique, not null, note: 'e.g. EXEMPT, NON_EXEMPT, EXEMPT_ADMIN, EXEMPT_PROF, EXEMPT_COMPUTER, EXEMPT_SALES, EXEMPT_HCE']
  label                  varchar(100) [not null]
  description            text
  flsa_classification_id integer      [note: 'FK → lkp_flsa_classification.id']
  overtime_eligible      boolean      [not null, default: true, note: 'Whether OT applies']
  sort_order             int          [not null, default: 0]
  is_active              boolean      [not null, default: true]
  is_default             boolean      [not null, default: false]
  created_at             timestamptz  [not null, default: `now()`]
  updated_at             timestamptz  [not null, default: `now()`]

  Note: 'FLSA exemption status assigned to a position or employee'
}

Table lkp_eeo_category {
  id                integer      [pk, increment]
  code              varchar(50)  [unique, not null, note: 'e.g. EXEC_SR_OFFICIALS, FIRST_MID_OFFICIALS, PROFESSIONALS']
  label             varchar(100) [not null]
  description       text
  eeo1_category_num varchar(10)  [not null, note: 'Official EEO-1 numeric category identifier']
  sort_order        int          [not null, default: 0]
  is_active         boolean      [not null, default: true]
  is_default        boolean      [not null, default: false]
  created_at        timestamptz  [not null, default: `now()`]
  updated_at        timestamptz  [not null, default: `now()`]

  Note: 'EEO-1 job category for federal compliance reporting'
}

// ────────────────────────────────────────────────────────────
// GROUP 4: ASSIGNMENT
// ────────────────────────────────────────────────────────────

Table lkp_assignment_type {
  id             integer      [pk, increment]
  code           varchar(50)  [unique, not null, note: 'e.g. PRIMARY, SECONDARY, ADDITIONAL, ACTING, INTERIM']
  label          varchar(100) [not null]
  description    text
  is_primary     boolean      [not null, default: false, note: 'Whether this type designates the primary/home assignment']
  allows_overlap boolean      [not null, default: true, note: 'Whether multiple assignments of this type can coexist']
  sort_order     int          [not null, default: 0]
  is_active      boolean      [not null, default: true]
  is_default     boolean      [not null, default: false]
  created_at     timestamptz  [not null, default: `now()`]
  updated_at     timestamptz  [not null, default: `now()`]

  Note: 'Type of work assignment (Primary, Secondary, Acting, etc.)'
}

Table lkp_assignment_status {
  id              integer      [pk, increment]
  code            varchar(50)  [unique, not null, note: 'e.g. ACTIVE, INACTIVE, PENDING, ENDED, SUSPENDED']
  label           varchar(100) [not null]
  description     text
  is_active_state boolean      [not null, default: true, note: 'Whether this status represents an active assignment']
  sort_order      int          [not null, default: 0]
  is_active       boolean      [not null, default: true]
  is_default      boolean      [not null, default: false]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of a work assignment'
}

// ────────────────────────────────────────────────────────────
// GROUP 5: COMPENSATION & PAY
// ────────────────────────────────────────────────────────────

Table lkp_compensation_rate_type {
  id              integer      [pk, increment]
  code            varchar(50)  [unique, not null, note: 'e.g. SALARY, HOURLY, DAILY, PIECE_RATE, COMMISSION, STIPEND']
  label           varchar(100) [not null]
  description     text
  is_annualized   boolean      [not null, default: false, note: 'Whether the rate is expressed as an annual figure']
  unit_of_measure varchar(30)  [note: 'Rate unit: YEAR, HOUR, DAY, UNIT, PERCENT, PERIOD']
  sort_order      int          [not null, default: 0]
  is_active       boolean      [not null, default: true]
  is_default      boolean      [not null, default: false]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]

  Note: 'How compensation is measured (salary, hourly, commission, etc.)'
}

Table lkp_compensation_status {
  id                 integer      [pk, increment]
  code               varchar(50)  [unique, not null, note: 'e.g. PROPOSED, APPROVED, ACTIVE, FROZEN, ENDED']
  label              varchar(100) [not null]
  description        text
  approval_status_id integer      [note: 'FK → lkp_approval_status.id']
  is_payable         boolean      [not null, default: false, note: 'Whether compensation is disbursable in this state']
  sort_order         int          [not null, default: 0]
  is_active          boolean      [not null, default: true]
  is_default         boolean      [not null, default: false]
  created_at         timestamptz  [not null, default: `now()`]
  updated_at         timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of a compensation record'
}

Table lkp_pay_frequency {
  id              integer      [pk, increment]
  code            varchar(50)  [unique, not null, note: 'e.g. WEEKLY, BIWEEKLY, SEMIMONTHLY, MONTHLY, QUARTERLY, ANNUAL']
  label           varchar(100) [not null]
  description     text
  periods_per_year int         [not null, note: 'Number of pay periods per year (52, 26, 24, 12, 4, 1)']
  sort_order      int          [not null, default: 0]
  is_active       boolean      [not null, default: true]
  is_default      boolean      [not null, default: false]
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]

  Note: 'Pay cycle frequency (weekly, biweekly, semimonthly, monthly, etc.)'
}

Table lkp_payroll_impact_type {
  id                integer       [pk, increment]
  code              varchar(50)   [unique, not null, note: 'e.g. PAID, UNPAID, PARTIAL_PAY, REDUCED_RATE, COMPANY_FUNDED, STATE_FUNDED']
  label             varchar(100)  [not null]
  description       text
  affects_gross_pay boolean       [not null, default: true, note: 'Whether this impact type modifies gross pay calculation']
  pay_percentage    decimal(5,2)  [note: 'Default pay percentage (100.00 = full pay, 0.00 = unpaid)']
  sort_order        int           [not null, default: 0]
  is_active         boolean       [not null, default: true]
  is_default        boolean       [not null, default: false]
  created_at        timestamptz   [not null, default: `now()`]
  updated_at        timestamptz   [not null, default: `now()`]

  Note: 'How an event or leave type impacts payroll (paid, unpaid, partial, etc.)'
}

// ────────────────────────────────────────────────────────────
// GROUP 6: LEAVE & APPROVAL
// ────────────────────────────────────────────────────────────

Table lkp_approval_status {
  id               integer      [pk, increment]
  code             varchar(50)  [unique, not null, note: 'e.g. DRAFT, PENDING, APPROVED, REJECTED, CANCELLED, ESCALATED']
  label            varchar(100) [not null]
  description      text
  is_approved_state boolean     [not null, default: false, note: 'Whether this state represents approval']
  sort_order       int          [not null, default: 0]
  is_active        boolean      [not null, default: true]
  is_default       boolean      [not null, default: false]
  created_at       timestamptz  [not null, default: `now()`]
  updated_at       timestamptz  [not null, default: `now()`]

  Note: 'Generic approval workflow status (used across leave, comp, documents, etc.)'
}

Table lkp_leave_type {
  id                     integer      [pk, increment]
  code                   varchar(50)  [unique, not null, note: 'e.g. VACATION, SICK, PERSONAL, FMLA, BEREAVEMENT, JURY_DUTY, MILITARY, PTO, STD, LTD']
  label                  varchar(100) [not null]
  description            text
  payroll_impact_type_id integer      [note: 'FK → lkp_payroll_impact_type.id; default payroll treatment']
  is_accrued             boolean      [not null, default: true, note: 'Whether this leave type accrues a balance']
  is_protected           boolean      [not null, default: false, note: 'Whether legally protected (FMLA, ADA, military)']
  requires_documentation boolean      [not null, default: false, note: 'Whether supporting docs are required']
  max_days_per_year      int          [note: 'Statutory or policy cap, if applicable']
  sort_order             int          [not null, default: 0]
  is_active              boolean      [not null, default: true]
  is_default             boolean      [not null, default: false]
  created_at             timestamptz  [not null, default: `now()`]
  updated_at             timestamptz  [not null, default: `now()`]

  Note: 'Classification of leave/absence (vacation, sick, FMLA, etc.)'
}

Table lkp_leave_status {
  id                 integer      [pk, increment]
  code               varchar(50)  [unique, not null, note: 'e.g. REQUESTED, APPROVED, IN_PROGRESS, COMPLETED, DENIED, CANCELLED']
  label              varchar(100) [not null]
  description        text
  approval_status_id integer      [note: 'FK → lkp_approval_status.id']
  is_on_leave        boolean      [not null, default: false, note: 'Whether this status means employee is actively on leave']
  sort_order         int          [not null, default: 0]
  is_active          boolean      [not null, default: true]
  is_default         boolean      [not null, default: false]
  created_at         timestamptz  [not null, default: `now()`]
  updated_at         timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of a leave request'
}

// ────────────────────────────────────────────────────────────
// GROUP 7: DOCUMENTS
// ────────────────────────────────────────────────────────────

Table lkp_document_type {
  id                  integer      [pk, increment]
  code                varchar(50)  [unique, not null, note: 'e.g. OFFER_LETTER, I9, W4, NDA, PERFORMANCE_REVIEW, POLICY_ACK, CONTRACT, CERTIFICATION, LICENSE']
  label               varchar(100) [not null]
  description         text
  requires_signature  boolean      [not null, default: false, note: 'Whether e-signature is required']
  retention_days      int          [note: 'Minimum retention period in days per policy/regulation']
  is_employee_visible boolean      [not null, default: true, note: 'Whether visible in employee self-service']
  sort_order          int          [not null, default: 0]
  is_active           boolean      [not null, default: true]
  is_default          boolean      [not null, default: false]
  created_at          timestamptz  [not null, default: `now()`]
  updated_at          timestamptz  [not null, default: `now()`]

  Note: 'Classification of HR documents (offer letter, I-9, W-4, NDA, etc.)'
}

Table lkp_document_status {
  id                 integer      [pk, increment]
  code               varchar(50)  [unique, not null, note: 'e.g. DRAFT, PENDING_SIGNATURE, SIGNED, EXPIRED, ARCHIVED, VOIDED, SUPERSEDED']
  label              varchar(100) [not null]
  description        text
  approval_status_id integer      [note: 'FK → lkp_approval_status.id; mapped approval state if doc requires approval']
  is_valid           boolean      [not null, default: false, note: 'Whether the document is considered legally valid in this state']
  sort_order         int          [not null, default: 0]
  is_active          boolean      [not null, default: true]
  is_default         boolean      [not null, default: false]
  created_at         timestamptz  [not null, default: `now()`]
  updated_at         timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of an HR document'
}

// ────────────────────────────────────────────────────────────
// GROUP 8: ONBOARDING
// ────────────────────────────────────────────────────────────

Table lkp_onboarding_plan_status {
  id         integer      [pk, increment]
  code       varchar(50)  [unique, not null, note: 'e.g. NOT_STARTED, IN_PROGRESS, BLOCKING_COMPLETE, COMPLETED, CANCELLED, ON_HOLD']
  label      varchar(100) [not null]
  description text
  sort_order int          [not null, default: 0]
  is_active  boolean      [not null, default: true]
  is_default boolean      [not null, default: false]
  created_at timestamptz  [not null, default: `now()`]
  updated_at timestamptz  [not null, default: `now()`]

  Note: 'Status of an onboarding plan instance'
}

Table lkp_onboarding_task_type {
  id                 integer      [pk, increment]
  code               varchar(50)  [unique, not null, note: 'e.g. DOCUMENT_SUBMISSION, TRAINING, EQUIPMENT_SETUP, SYSTEM_ACCESS, ORIENTATION, MENTOR_ASSIGNMENT, BENEFITS_ENROLLMENT, POLICY_ACK']
  label              varchar(100) [not null]
  description        text
  document_type_id   integer      [note: 'FK → lkp_document_type.id; linked document type if this is a doc task']
  default_due_days   int          [note: 'Default number of days after hire to complete']
  is_employee_action boolean      [not null, default: true, note: 'Whether the new hire performs this task (vs HR/IT)']
  is_blocking        boolean      [not null, default: false, note: 'Whether this task blocks plan completion']
  sort_order         int          [not null, default: 0]
  is_active          boolean      [not null, default: true]
  is_default         boolean      [not null, default: false]
  created_at         timestamptz  [not null, default: `now()`]
  updated_at         timestamptz  [not null, default: `now()`]

  Note: 'Category of onboarding task (document, training, equipment, access, etc.)'
}

Table lkp_onboarding_task_status {
  id                integer      [pk, increment]
  code              varchar(50)  [unique, not null, note: 'e.g. PENDING, IN_PROGRESS, COMPLETED, SKIPPED, OVERDUE, BLOCKED, WAIVED']
  label             varchar(100) [not null]
  description       text
  approval_status_id integer     [note: 'FK → lkp_approval_status.id; if task requires approval']
  is_complete_state boolean      [not null, default: false, note: 'Whether this status counts toward plan completion']
  sort_order        int          [not null, default: 0]
  is_active         boolean      [not null, default: true]
  is_default        boolean      [not null, default: false]
  created_at        timestamptz  [not null, default: `now()`]
  updated_at        timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of an individual onboarding task'
}

// ────────────────────────────────────────────────────────────
// GROUP 9: ORGANIZATION
// ────────────────────────────────────────────────────────────

Table lkp_legal_entity_type {
  id         integer      [pk, increment]
  code       varchar(50)  [not null, unique]
  label      varchar(100) [not null]
  is_active  boolean      [not null, default: true]
  sort_order integer      [not null, default: 0]
}

Table lkp_org_unit_type {
  id             integer      [pk, increment]
  code           varchar(50)  [unique, not null, note: 'e.g. LEGAL_ENTITY, COMPANY, DIVISION, DEPARTMENT, TEAM, COST_CENTER, BUSINESS_UNIT, LOCATION, REGION']
  label          varchar(100) [not null]
  description    text
  allows_children boolean     [not null, default: true, note: 'Whether this unit type can have child units']
  sort_order     int          [not null, default: 0]
  is_active      boolean      [not null, default: true]
  is_default     boolean      [not null, default: false]
  created_at     timestamptz  [not null, default: `now()`]
  updated_at     timestamptz  [not null, default: `now()`]

  Note: 'Type of organizational unit (legal entity, division, department, location, etc.)'
}

Table lkp_org_status {
  id             integer      [pk, increment]
  code           varchar(50)  [unique, not null, note: 'e.g. ACTIVE, INACTIVE, PENDING_ACTIVATION, MERGED, DISSOLVED, ARCHIVED']
  label          varchar(100) [not null]
  description    text
  is_operational boolean      [not null, default: true, note: 'Whether the org unit is operationally functional']
  sort_order     int          [not null, default: 0]
  is_active      boolean      [not null, default: true]
  is_default     boolean      [not null, default: false]
  created_at     timestamptz  [not null, default: `now()`]
  updated_at     timestamptz  [not null, default: `now()`]

  Note: 'Lifecycle status of an organizational unit'
}

Table lkp_work_location_type {
  id               integer      [pk, increment]
  code             varchar(50)  [unique, not null, note: 'e.g. OFFICE, REMOTE, HYBRID, FIELD, CLIENT_SITE, WAREHOUSE']
  label            varchar(100) [not null]
  description      text
  is_on_site       boolean      [not null, default: true, note: 'Whether employees physically report to this location']
  requires_address boolean      [not null, default: true, note: 'Whether a physical address is required']
  sort_order       int          [not null, default: 0]
  is_active        boolean      [not null, default: true]
  is_default       boolean      [not null, default: false]
  created_at       timestamptz  [not null, default: `now()`]
  updated_at       timestamptz  [not null, default: `now()`]

  Note: 'Classification of work locations (office, remote, hybrid, field, etc.)'
}

// ────────────────────────────────────────────────────────────
// GROUP 10: JOB & POSITION
// ────────────────────────────────────────────────────────────

Table lkp_job_status {
  id         integer      [pk, increment]
  code       varchar(50)  [unique, not null, note: 'e.g. ACTIVE, FROZEN, ABOLISHED, UNDER_REVIEW, PENDING_APPROVAL, INACTIVE']
  label      varchar(100) [not null]
  description text
  is_hirable boolean      [not null, default: true, note: 'Whether positions under this job can be filled']
  sort_order int          [not null, default: 0]
  is_active  boolean      [not null, default: true]
  is_default boolean      [not null, default: false]
  created_at timestamptz  [not null, default: `now()`]
  updated_at timestamptz  [not null, default: `now()`]

  Note: 'Status of a job definition/title in the catalog'
}

Table lkp_position_status {
  id         integer      [pk, increment]
  code       varchar(50)  [unique, not null, note: 'e.g. OPEN, FILLED, FROZEN, ABOLISHED, PENDING_BUDGET']
  label      varchar(100) [not null]
  description text
  is_fillable boolean     [not null, default: true, note: 'Whether this position can accept an incumbent']
  is_occupied boolean     [not null, default: false, note: 'Whether this status implies a current incumbent']
  sort_order int          [not null, default: 0]
  is_active  boolean      [not null, default: true]
  is_default boolean      [not null, default: false]
  created_at timestamptz  [not null, default: `now()`]
  updated_at timestamptz  [not null, default: `now()`]

  Note: 'Status of an individual position (headcount slot)'
}


// ============================================================
// PLATFORM
// ============================================================

Table platform_audit_event {
  audit_event_id      uuid         [pk, not null,   note: "System-generated"]
  tenant_id           uuid         [not null,       note: "Owning tenant"]
  event_timestamp     timestamptz  [not null,       note: "Server UTC time of the event"]
  event_type          varchar(50)  [not null,       note: "CREATE | UPDATE | DELETE | STATUS_CHANGE | VIEW | EXPORT | LOGIN | LOGOUT | LOGIN_FAILED | ENROLL | DISENROLL"]
  module_name         varchar(30)  [null,           note: "HRIS | PAYROLL | BENEFITS | TIME | REPORTING | PLATFORM"]
  entity_type         varchar(100) [not null,       note: "PayrollRun | PayrollContext | Employment | CompensationRecord | etc."]
  entity_id           uuid         [null,           note: "PK of the affected record; null for login events"]
  parent_entity_type  varchar(100) [null,           note: "Owning entity type, e.g. PayrollContext when entity is PayrollPeriod"]
  parent_entity_id    uuid         [null,           note: "PK of the owning record"]
  actor_user_id       uuid         [not null,       note: "Keycloak subject claim; Guid.Empty for system jobs"]
  actor_display_name  varchar(200) [null,           note: "Denormalised display name at time of event"]
  change_summary      varchar(500) [null,           note: "Human-readable one-line description of what changed"]
  before_state_json   text         [null,           note: "JSON snapshot of relevant fields before operation"]
  after_state_json    text         [null,           note: "JSON snapshot of relevant fields after operation"]
  outcome             varchar(20)  [not null,       note: "SUCCESS | FAILURE | PARTIAL"]
  failure_reason      varchar(500) [null,           note: "Populated when outcome = FAILURE"]
  ip_address          varchar(45)  [null,           note: "IPv4 or IPv6 of the client connection"]
  session_id          varchar(200) [null,           note: "Blazor circuit ID or HTTP session ID"]

  indexes {
    tenant_id
    event_timestamp
    actor_user_id
    (entity_type, entity_id)
    (tenant_id, event_timestamp)
    (tenant_id, entity_type, entity_id)
  }
}


// ============================================================
// CORE HRIS TABLES
// ============================================================

Table person {
  person_id                   uuid          [pk, not null, note: "System-generated. Immutable. Enduring human identity key."]
  person_number               varchar(50)   [null, note: "Optional human-facing or integration-facing identifier"]
  legal_first_name            varchar(100)  [not null]
  legal_middle_name           varchar(100)  [null]
  legal_last_name             varchar(100)  [not null]
  name_suffix                 varchar(20)   [null]
  preferred_name              varchar(100)  [null]
  date_of_birth               date          [not null]
  national_identifier         varchar(500)  [null, note: "Encrypted at rest. SSN for US. Access-controlled."]
  national_identifier_type    varchar(50)   [null, note: "SSN, SIN, NIN, etc."]
  gender                      varchar(50)   [null, note: "Self-identified; controlled vocabulary"]
  pronouns                    varchar(100)  [null, note: "Self-identified"]
  citizenship_status          varchar(100)  [null]
  work_authorization_status   varchar(100)  [null]
  work_authorization_exp_date date          [null]
  language_preference         varchar(20)   [null]
  marital_status              varchar(50)   [null]
  veteran_status              varchar(50)   [null]
  disability_status           varchar(50)   [null]
  person_status_id            integer       [not null, note: "FK → lkp_person_status.id"]
  creation_timestamp          timestamptz   [not null]
  last_update_timestamp       timestamptz   [not null]
  last_updated_by             varchar(200)  [not null]

  indexes {
    person_number
    person_status_id
    (legal_last_name, legal_first_name)
  }
}

Table employee_event {
  event_id              uuid        [pk, not null, note: "System-generated. Immutable."]
  employment_id         uuid        [not null]
  event_type_id         integer     [not null, note: "FK → lkp_employee_event_type.id"]
  effective_date        date        [not null]
  event_reason          varchar(200) [null]
  notes                 varchar(1000) [null]
  initiated_by          uuid        [not null]
  approved_by           uuid        [null]
  approval_timestamp    timestamptz [null]
  creation_timestamp    timestamptz [not null]

  indexes {
    employment_id
    event_type_id
    effective_date
    (employment_id, effective_date)
  }
}

Table person_address {
  person_address_id       uuid         [pk, not null]
  person_id               uuid         [not null]
  address_type            varchar(50)  [not null, note: "PRIMARY, MAILING, PRIOR"]
  address_line_1          varchar(200) [not null]
  address_line_2          varchar(200) [null]
  city                    varchar(100) [not null]
  state_code              varchar(10)  [not null, note: "ISO 3166-2"]
  postal_code             varchar(20)  [not null]
  country_code            varchar(5)   [not null, note: "ISO 3166-1 alpha-2"]
  phone_primary           varchar(30)  [null]
  phone_secondary         varchar(30)  [null]
  email_personal          varchar(200) [null]
  effective_start_date    date         [not null]
  effective_end_date      date         [null]
  created_by              uuid         [not null]
  creation_timestamp      timestamptz  [not null]

  indexes {
    person_id
    (person_id, address_type, effective_start_date)
  }
}

Table person_emergency_contact {
  emergency_contact_id    uuid         [pk, not null]
  person_id               uuid         [not null]
  contact_name            varchar(200) [not null]
  relationship            varchar(100) [null]
  phone                   varchar(30)  [null]
  email                   varchar(200) [null]
  primary_flag            boolean      [not null, default: false]
  created_by              uuid         [not null]
  creation_timestamp      timestamptz  [not null]

  indexes {
    person_id
  }
}

Table org_unit {
  org_unit_id             uuid        [pk, not null, note: "System-generated. Immutable."]
  org_unit_type_id        integer     [not null, note: "FK → lkp_org_unit_type.id"]
  org_unit_code           varchar(50) [not null]
  org_unit_name           varchar(200) [not null]
  parent_org_unit_id      uuid        [null, note: "Null for root nodes; must not create cycles"]
  legal_entity_id         uuid        [null, note: "FK → org_unit.org_unit_id (LEGAL_ENTITY type). Self-referencing for legal entity rows. All other org unit types point to their owning entity."]
  legal_entity_type_id    integer     [null, note: "FK → lkp_legal_entity_type.id"]
  org_status_id           integer     [not null, note: "FK → lkp_org_status.id"]
  effective_start_date    date        [not null]
  effective_end_date      date        [null]
  // Legal entity additional fields
  tax_registration_number varchar(50) [null, note: "EIN for US legal entities"]
  country_code            varchar(5)  [null, note: "ISO 3166-1 alpha-2; required for legal entities"]
  state_of_incorporation  varchar(10) [null]
  // Location additional fields
  address_line_1          varchar(200) [null]
  address_line_2          varchar(200) [null]
  city                    varchar(100) [null]
  state_code              varchar(10)  [null, note: "US state code; drives tax jurisdiction"]
  postal_code             varchar(20)  [null]
  locality_code           varchar(50)  [null, note: "Local tax jurisdiction code"]
  work_location_type_id   integer      [null, note: "FK → lkp_work_location_type.id"]
  created_by              uuid         [not null]
  creation_timestamp      timestamptz  [not null]
  last_updated_by         uuid         [not null]
  last_update_timestamp   timestamptz  [not null]

  indexes {
    org_unit_type_id
    org_status_id
    parent_org_unit_id
    legal_entity_id
    org_unit_code
  }
}

Table job {
  job_id                  uuid        [pk, not null, note: "System-generated. Immutable."]
  legal_entity_id         uuid        [not null, note: "FK → org_unit.org_unit_id (LEGAL_ENTITY type). Jobs are scoped to a legal entity."]
  job_code                varchar(50) [not null, note: "Unique within legal_entity_id; not globally unique."]
  job_title               varchar(200) [not null]
  job_family              varchar(100) [null]
  job_level               varchar(50)  [null]
  flsa_classification_id  integer      [not null, note: "FK → lkp_flsa_classification.id"]
  eeo_category_id         integer      [not null, note: "FK → lkp_eeo_category.id"]
  job_status_id           integer      [not null, note: "FK → lkp_job_status.id"]
  effective_start_date    date         [not null]
  effective_end_date      date         [null]
  created_by              uuid         [not null]
  creation_timestamp      timestamptz  [not null]
  last_updated_by         uuid         [not null]
  last_update_timestamp   timestamptz  [not null]

  indexes {
    legal_entity_id
    (legal_entity_id, job_code) [unique]
    job_status_id
    flsa_classification_id
  }
}

Table position {
  position_id             uuid        [pk, not null, note: "System-generated. Immutable."]
  job_id                  uuid        [not null]
  org_unit_id             uuid        [not null]
  position_title          varchar(200) [null, note: "Override title; if null, inherits from job_title"]
  headcount_budget        int          [null]
  position_status_id      integer      [not null, note: "FK → lkp_position_status.id"]
  effective_start_date    date         [not null]
  effective_end_date      date         [null]
  created_by              uuid         [not null]
  creation_timestamp      timestamptz  [not null]
  last_updated_by         uuid         [not null]
  last_update_timestamp   timestamptz  [not null]

  indexes {
    job_id
    org_unit_id
    position_status_id
  }
}

Table employment {
  employment_id                 uuid        [pk, not null, note: "System-generated. Immutable. Payroll anchor."]
  person_id                     uuid        [not null]
  legal_entity_id               uuid        [not null, note: "Org unit of type LEGAL_ENTITY"]
  employer_id                   uuid        [not null, note: "Same as legal_entity_id in standard deployments"]
  employee_number               varchar(50) [not null]
  employment_type_id            integer     [not null, note: "FK → lkp_employment_type.id"]
  employment_start_date         date        [not null]
  employment_end_date           date        [null]
  original_hire_date            date        [null]
  termination_date              date        [null]
  employment_status_id          integer     [not null, note: "FK → lkp_employment_status.id"]
  full_part_time_status_id      integer     [not null, note: "FK → lkp_full_part_time_status.id"]
  regular_temporary_status_id   integer     [not null, note: "FK → lkp_regular_temporary_status.id"]
  flsa_status_id                integer     [not null, note: "FK → lkp_flsa_status.id"]
  payroll_context_id            uuid        [null, note: "Nullable — absent in HRIS-only deployments"]
  primary_work_location_id      uuid        [not null, note: "References org_unit of type LOCATION"]
  primary_department_id         uuid        [not null, note: "References org_unit of type DEPARTMENT"]
  manager_employment_id         uuid        [null, note: "Direct manager; self-referencing"]
  rehire_flag                   boolean     [not null, default: false]
  prior_employment_id           uuid        [null, note: "Prior episode on rehire"]
  primary_flag                  boolean     [not null, default: true, note: "True if primary when concurrent employments exist"]
  payroll_eligibility_flag      boolean     [not null, default: true]
  benefits_eligibility_flag     boolean     [not null, default: true]
  time_tracking_required_flag   boolean     [not null, default: false]
  creation_timestamp            timestamptz [not null]
  last_update_timestamp         timestamptz [not null]
  last_updated_by               varchar(200) [not null]

  indexes {
    person_id
    legal_entity_id
    employment_status_id
    employee_number
    manager_employment_id
    prior_employment_id
    payroll_context_id
    primary_work_location_id
    primary_department_id
  }
}

Table assignment {
  assignment_id           uuid        [pk, not null, note: "System-generated. Immutable."]
  employment_id           uuid        [not null, note: "Payroll anchor — never person_id"]
  job_id                  uuid        [not null]
  position_id             uuid        [null, note: "Null if position management not in use"]
  department_id           uuid        [not null, note: "References org_unit"]
  location_id             uuid        [not null, note: "References org_unit of type LOCATION; drives tax jurisdiction"]
  payroll_context_id      uuid        [null]
  plan_id                 uuid        [null]
  assignment_type_id      integer     [not null, note: "FK → lkp_assignment_type.id"]
  assignment_status_id    integer     [not null, note: "FK → lkp_assignment_status.id"]
  assignment_priority     int         [null]
  assignment_start_date   date        [not null]
  assignment_end_date     date        [null]
  created_by              uuid        [not null]
  creation_timestamp      timestamptz [not null]
  last_updated_by         uuid        [not null]
  last_update_timestamp   timestamptz [not null]

  indexes {
    employment_id
    job_id
    position_id
    location_id
    department_id
    assignment_status_id
    assignment_type_id
    (employment_id, assignment_type_id, assignment_start_date)
  }
}

Table compensation_record {
  compensation_id           uuid          [pk, not null, note: "System-generated. Immutable."]
  employment_id             uuid          [not null, note: "Payroll anchor"]
  rate_type_id              integer       [not null, note: "FK → lkp_compensation_rate_type.id"]
  base_rate                 decimal(18,4) [not null]
  rate_currency             varchar(5)    [not null, default: 'USD', note: "ISO 4217"]
  annual_equivalent         decimal(18,4) [null, note: "System-calculated"]
  pay_frequency_id          integer       [not null, note: "FK → lkp_pay_frequency.id"]
  effective_start_date      date          [not null]
  effective_end_date        date          [null]
  compensation_status_id    integer       [not null, note: "FK → lkp_compensation_status.id"]
  change_reason_code        varchar(50)   [not null]
  approval_status_id        integer       [not null, note: "FK → lkp_approval_status.id"]
  approved_by               uuid          [null]
  approval_timestamp        timestamptz   [null]
  primary_rate_flag         boolean       [not null, default: false]
  created_by                uuid          [not null]
  creation_timestamp        timestamptz   [not null]
  last_updated_by           uuid          [not null]
  last_update_timestamp     timestamptz   [not null]

  indexes {
    employment_id
    compensation_status_id
    effective_start_date
    (employment_id, rate_type_id, effective_start_date)
    primary_rate_flag
  }
}

Table leave_request {
  leave_request_id        uuid          [pk, not null, note: "System-generated. Immutable."]
  employment_id           uuid          [not null]
  leave_type_id           integer       [not null, note: "FK → lkp_leave_type.id"]
  request_date            date          [not null]
  leave_start_date        date          [not null]
  leave_end_date          date          [not null]
  actual_return_date      date          [null]
  leave_status_id         integer       [not null, note: "FK → lkp_leave_status.id"]
  leave_reason_code       varchar(50)   [not null]
  payroll_impact_type_id  integer       [not null, note: "FK → lkp_payroll_impact_type.id"]
  leave_balance_impact    decimal(10,4) [null, note: "Hours or days deducted from balance"]
  approved_by             uuid          [null]
  approval_timestamp      timestamptz   [null]
  hr_contact_id           uuid          [null]
  fmla_eligible_flag      boolean       [null, default: false]
  notes                   varchar(1000) [null]
  created_by              uuid          [not null]
  creation_timestamp      timestamptz   [not null]
  last_updated_by         uuid          [not null]
  last_update_timestamp   timestamptz   [not null]

  indexes {
    employment_id
    leave_status_id
    leave_type_id
    leave_start_date
    (employment_id, leave_start_date, leave_end_date)
  }
}

Table document {
  document_id                 uuid         [pk, not null, note: "System-generated. Immutable."]
  person_id                   uuid         [not null, note: "Always associated with a Person"]
  employment_id               uuid         [null, note: "Null for person-level documents"]
  document_type_id            integer      [not null, note: "FK → lkp_document_type.id"]
  document_name               varchar(200) [not null]
  document_version            int          [not null, default: 1]
  document_status_id          integer      [not null, note: "FK → lkp_document_status.id"]
  effective_date              date         [not null]
  expiration_date             date         [null]
  storage_reference           varchar(500) [not null, note: "Secure reference to stored file"]
  file_format                 varchar(20)  [not null]
  upload_date                 timestamptz  [not null]
  uploaded_by                 uuid         [not null]
  verified_by                 uuid         [null]
  verification_date           timestamptz  [null]
  superseded_by_document_id   uuid         [null]
  legal_hold_flag             boolean      [not null, default: false, note: "True if document is under legal hold; prevents archival and disposal"]
  created_by                  uuid         [not null]
  creation_timestamp          timestamptz  [not null]

  indexes {
    person_id
    employment_id
    document_type_id
    document_status_id
    expiration_date
    superseded_by_document_id
  }
}

Table document_download_audit {
  audit_id         uuid        [pk]
  document_id      uuid        [not null, note: "FK → document.document_id"]
  accessed_by      uuid        [not null, note: "Employment or user ID of the accessor"]
  access_timestamp timestamptz [not null]

  indexes {
    document_id
    accessed_by
  }
}

Table person_social_profile {
  person_id       uuid         [pk, ref: - person.person_id]
  photo_data      bytea        [null]
  photo_mime_type varchar(50)  [null]
  bio_text        varchar(1000) [null]
  updated_at      timestamptz  [not null, default: `now()`]
}

Table work_queue_item {
  work_queue_item_id uuid         [pk]
  item_type          varchar(50)  [not null]
  reference_id       uuid         [not null]
  reference_type     varchar(50)  [not null]
  employment_id      uuid         [null]
  assigned_role      varchar(100) [not null]
  status             varchar(20)  [not null, default: 'OPEN']
  priority           varchar(20)  [not null, default: 'NORMAL']
  title              varchar(200) [not null]
  description        text         [null]
  due_date           date         [null]
  created_at         timestamptz  [not null]
  resolved_at        timestamptz  [null]
  resolved_by        uuid         [null]

  indexes {
    employment_id
    reference_id
    (assigned_role, status)
    status
  }
}

Table onboarding_plan {
  onboarding_plan_id        uuid        [pk, not null, note: "System-generated. Immutable."]
  employment_id             uuid        [not null]
  plan_template_id          uuid        [null]
  plan_status_id            integer     [not null, note: "FK → lkp_onboarding_plan_status.id"]
  target_start_date         date        [not null]
  completion_date           date        [null]
  assigned_hr_contact_id    uuid        [null]
  created_by                uuid        [not null]
  creation_timestamp        timestamptz [not null]
  last_updated_by           uuid        [not null]
  last_update_timestamp     timestamptz [not null]

  indexes {
    employment_id
    plan_status_id
  }
}

Table onboarding_task {
  task_id               uuid        [pk, not null, note: "System-generated. Immutable."]
  onboarding_plan_id    uuid        [not null]
  task_type_id          integer     [not null, note: "FK → lkp_onboarding_task_type.id"]
  task_name             varchar(200) [not null]
  task_owner_role       varchar(100) [not null]
  task_owner_user_id    uuid        [null]
  due_date              date        [not null]
  completion_date       date        [null]
  task_status_id        integer     [not null, note: "FK → lkp_onboarding_task_status.id"]
  blocking_flag         boolean     [not null, default: false]
  waiver_reason         varchar(500) [null]
  waived_by             uuid        [null]
  created_by            uuid        [not null]
  creation_timestamp    timestamptz [not null]

  indexes {
    onboarding_plan_id
    task_status_id
    blocking_flag
    (onboarding_plan_id, blocking_flag, task_status_id)
  }
}

Table leave_balance {
  leave_balance_id      uuid          [pk, not null, note: "System-generated. Immutable."]
  employment_id         uuid          [not null]
  leave_type_id         integer       [not null, note: "FK → lkp_leave_type.id"]
  available_balance     decimal(10,4) [not null, default: 0]
  pending_balance       decimal(10,4) [not null, default: 0]
  used_balance          decimal(10,4) [not null, default: 0]
  entitlement_total     decimal(10,4) [not null, default: 0]
  plan_year_start       date          [not null]
  plan_year_end         date          [not null]
  last_accrual_date     date          [null]
  last_updated_run_id   uuid          [null]
  created_timestamp     timestamptz   [not null]
  last_update_timestamp timestamptz   [not null]

  indexes {
    employment_id
    (employment_id, leave_type_id, plan_year_start)
  }
}

Table report_execution_history {
  execution_id          uuid         [pk, not null]
  report_id             varchar(50)  [not null, note: "Report identifier e.g. PAY-RPT-001"]
  report_title          varchar(200) [not null, note: "Display title at time of execution"]
  requested_by          uuid         [not null, note: "Employment ID or user ID of requesting user"]
  execution_status      varchar(20)  [not null, note: "RUNNING, COMPLETED, FAILED, ASYNC_PENDING"]
  parameters_json       text         [not null, note: "JSON serialisation of ReportParameters used for this execution"]
  row_count             integer      [note: "Null until execution completes"]
  export_format         varchar(10)  [note: "CSV, XLSX, PDF, or null for on-screen view"]
  storage_reference     varchar(500) [note: "Non-null when export file retained in storage"]
  async_job_id          uuid         [note: "Non-null when execution submitted as async job"]
  started_at            timestamptz  [not null]
  completed_at          timestamptz  [note: "Null until execution reaches terminal state"]
  error_message         text         [note: "Non-null on FAILED status"]
  created_timestamp     timestamptz  [not null]
  last_update_timestamp timestamptz  [not null]

  indexes {
    requested_by                 [name: "idx_report_execution_requested_by"]
    (report_id, started_at)      [name: "idx_report_execution_report_date"]
    (requested_by, started_at)   [name: "idx_report_execution_user_date"]
    execution_status             [name: "idx_report_execution_status"]
  }
}


